# === LLM Provider Priority: Cloudflare → Gemini → Local Template ===

# 1️⃣ Cloudflare Workers AI (primary - rẻ nhất, free 10k neurons/day)
# Lấy Account ID tại: dash.cloudflare.com (góc phải)
# Tạo API Token tại: dash.cloudflare.com/profile/api-tokens (permission: Workers AI - Run)
CLOUDFLARE_ACCOUNT_ID=a9d75034ac3aac84e09dc47483175989
CLOUDFLARE_API_TOKEN=your_cloudflare_token_here
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# 2️⃣ Gemini (fallback - cần key active)
GEMINI_API_KEY=your_gemini_api_key_here

# 3️⃣ Local FAISS template (always available - no internet needed)
AI_SERVICE_PORT=8001
HF_HUB_DISABLE_SYMLINKS_WARNING=1
